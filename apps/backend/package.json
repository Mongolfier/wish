{
	"name": "@wish/backend",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"dev": "uv run uvicorn wish_api.main:app --reload --host 0.0.0.0 --port 8000",
		"dev:pip": "python -m uvicorn wish_api.main:app --reload --host 0.0.0.0 --port 8000",
		"start": "uv run uvicorn wish_api.main:app --host 0.0.0.0 --port 8000",
		"start:pip": "python -m uvicorn wish_api.main:app --host 0.0.0.0 --port 8000",
		"test": "uv run pytest",
		"test:run": "uv run pytest -q",
		"test:pip": "python -m pytest -q",
		"lint": "node -e \"process.exit(0)\""
	}
}
