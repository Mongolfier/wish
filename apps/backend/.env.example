# Database
DATABASE_URL=sqlite:///./wish.db
# DATABASE_URL=postgresql+psycopg://wish:wish@localhost:5432/wish

# Session & OAuth state signing (min 32 chars in production)
SECRET_KEY=dev-secret-change-in-production-min-32-chars!!

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public URL of the Next.js app (used after OAuth success redirect)
OAUTH_REDIRECT_BASE=http://localhost:3000
FRONTEND_DEFAULT_LOCALE=ru

# Google OAuth redirect URI — add the same value to Google Cloud Console → OAuth client → Authorized redirect URIs
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Production example:
# OAUTH_REDIRECT_BASE=https://wish-time.ru
# GOOGLE_OAUTH_REDIRECT_URI=https://wish-time.ru/api/auth/google/callback
# ALLOWED_ORIGINS=https://wish-time.ru
# COOKIE_SECURE=true

# Session cookie
SESSION_COOKIE_NAME=wish_session
SESSION_MAX_AGE_SECONDS=2592000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Selectel Cloud Mail — https://my.selectel.ru/
# Port 1127 = TLS (SSL), 1126 = plain / STARTTLS
SMTP_HOST=smtp.mail.selcloud.ru
SMTP_PORT=1127
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_FALLBACK_STARTTLS=true
SMTP_FALLBACK_PORT=1126
SMTP_FROM=noreply@wish-time.ru

# Set true only when SMTP is unavailable (logs code to API console and response header).
SMTP_DEV_LOG_CODES=false

# Domain verification (DNS TXT at @):
# @ TXT "<key-from-selectel-panel>"
