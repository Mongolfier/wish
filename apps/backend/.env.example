# dev — Swagger UI at /docs; production/docker — docs disabled
ENVIRONMENT=dev

# Database
DATABASE_URL=sqlite:///./wish.db
# DATABASE_URL=postgresql+psycopg://wish:wish@localhost:5432/wish

# Registration — direct POST /api/auth/register (disabled in production)
DIRECT_REGISTER_ENABLED=true

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example (see committed `.env.prod`):
# ALLOWED_ORIGINS=https://wish-time.ru
# COOKIE_SECURE=true
# DIRECT_REGISTER_ENABLED=false
# DATABASE_URL, SMTP_PASSWORD — GitHub Actions secrets, injected at deploy
# POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB — GitHub Actions secrets for docker-compose db service

# Session cookie
SESSION_COOKIE_NAME=wish_session
SESSION_MAX_AGE_SECONDS=2592000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Selectel Cloud Mail — https://my.selectel.ru/
# Port 1127 = TLS (SSL), 1126 = plain / STARTTLS
SMTP_HOST=smtp.mail.selcloud.ru
SMTP_PORT=1127
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_FALLBACK_STARTTLS=true
SMTP_FALLBACK_PORT=1126
SMTP_FROM=noreply@wish-time.ru

# Set true only when SMTP is unavailable (logs code to API console and response header).
SMTP_DEV_LOG_CODES=false
