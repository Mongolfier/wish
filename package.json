{
	"name": "wish",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter @wish/web dev",
		"build": "pnpm --filter @wish/web build",
		"lint": "pnpm -r lint --fix",
		"lint:css": "pnpm --filter @wish/web run lint:css --fix",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
		"storybook": "pnpm --filter @wish/ui-kit storybook",
		"build:storybook": "pnpm --filter @wish/ui-kit build:storybook",
		"build:ui-kit": "pnpm --filter @wish/ui-kit build",
		"test": "vitest",
		"test:run": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"prepare": "husky"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"husky": "^9.1.7",
		"prettier": "^3.3.3",
		"prettier-config": "workspace:*",
		"vitest": "^4.0.18"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
