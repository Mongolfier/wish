{
	"name": "my-wish",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"engines": {
		"node": ">=20",
		"pnpm": ">=10"
	},
	"contributors": [
		"Dmitry Mumrenkov <dmitrymumrenkov@gmail.com>",
		"Nikolaj Kashirskij <nikolajkashirskij@gmail.com>"
	],
	"prettier": "prettier-config",
	"scripts": {
		"dev": "pnpm run build:ui-kit && pnpm run build:api-client && pnpm --filter @wish/web run dev",
		"dev:watch": "pnpm run build:ui-kit && pnpm run build:api-client && pnpm --parallel --filter @wish/ui-kit --filter @wish/web run dev",
		"build": "pnpm run build:ui-kit && pnpm run build:api-client && pnpm --filter @wish/web build",
		"lint": "pnpm -r lint",
		"lint:css": "pnpm -r run lint:css",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
		"storybook": "pnpm --filter @wish/ui-kit storybook",
		"build:storybook": "pnpm --filter @wish/ui-kit build:storybook",
		"build:ui-kit": "pnpm --filter @wish/ui-kit build",
		"test": "vitest",
		"test:run": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:a11y": "playwright test e2e/a11y.spec.ts",
		"api:dev": "pnpm --filter @wish/backend run dev",
		"api:openapi": "pnpm --filter @wish/backend run openapi:export && pnpm --filter @wish/api-client run generate && pnpm --filter @wish/api-client run build",
		"build:api-client": "pnpm --filter @wish/api-client run build",
		"prepare": "husky"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@playwright/test": "^1.58.2",
		"@types/node": "^24.10.13",
		"husky": "^9.1.7",
		"prettier": "^3.3.3",
		"prettier-config": "workspace:*",
		"typescript": "~5.9.3",
		"vitest": "^4.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"overrides": {
			"minimatch@>=10.0.0": "^10.2.3",
			"fast-uri": "^3.1.2",
			"ws": "^8.21.0",
			"postcss@>=8.0.0": "^8.5.10",
			"brace-expansion@>=5.0.0": "^5.0.6",
			"js-yaml@>=4.0.0": "^4.2.0",
			"esbuild@>=0.27.0": "^0.28.1",
			"@babel/core": "^7.29.6"
		}
	},
	"packageManager": "pnpm@10.33.0"
}
